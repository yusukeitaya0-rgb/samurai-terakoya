        "'''\n",
        "#台形の面積\n",
        "上辺：10cm\n",
        "下辺：20cm\n",
        "高さ：5cm\n",
        "\n",
        "公式：台形の面積 =（上辺＋下辺）× 高さ ÷ 2\n",
        "'''\n",
        "top_side=10\n",
        "bottom_side=20\n",
        "height=5\n",
        "\n",
        "area=(top_side+bottom_side)*height/2\n",
        "\n",
        "print(f\"{area}㎠\")"
